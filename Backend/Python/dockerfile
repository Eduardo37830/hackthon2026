# syntax=docker/dockerfile:1

# =========================
# Build stage
# =========================
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1 \
	PIP_NO_CACHE_DIR=1 \
	UV_COMPILE_BYTECODE=1 \
	UV_LINK_MODE=copy

WORKDIR /app

# Dependencias de compilacion para paquetes nativos (ej. psycopg2)
RUN apt-get update && apt-get install -y --no-install-recommends \
	build-essential \
	libpq-dev \
	&& rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip && pip install uv

# Copia primero archivos de dependencias para mejorar cache
COPY pyproject.toml uv.lock ./

# Crea entorno y descarga dependencias bloqueadas
RUN uv sync --frozen --no-dev

# Copia el codigo y valida que el lockfile resuelve con el proyecto actual
COPY . .
RUN uv sync --frozen --no-dev

# =========================
# Runtime stage
# =========================
FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1 \
	PORT=8000 \
	PATH="/app/.venv/bin:${PATH}"

WORKDIR /app

# Solo dependencias necesarias en runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
	libpq5 \
	libglib2.0-0 \
	libgl1 \
	libsm6 \
	libxext6 \
	libxrender1 \
	libxcb1 \
	libgomp1 \
	curl \
	&& rm -rf /var/lib/apt/lists/*

# Usuario no root para endurecer seguridad
RUN groupadd --system app && useradd --system --gid app --create-home app

COPY --from=builder --chown=app:app /app /app

USER app

# ========= INICIO DESCARGA DE MODELOS =========
# Creamos la carpeta weights
RUN mkdir -p /app/weights

# Instalamos gdown usando el entorno virtual que ya configuró Camilo
RUN pip install gdown

# Descargamos los dos modelos (SOLO EL ID)
RUN gdown --id 17pw7LZA4Ej82bium_VGWU75WQC2jDrhA -O /app/weights/best.pt
RUN gdown --id 1ET0bdzAnyidsTV_QE4Qr_e9nKqYmxO9g -O /app/weights/yolo26n.pt
# ==============================================

EXPOSE 8000

# Healthcheck util para orquestadores y Azure
HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
	CMD curl --fail http://127.0.0.1:${PORT}/ || exit 1

# Azure suele inyectar PORT; se usa ese valor cuando exista
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT}"]
